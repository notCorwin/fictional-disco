{
  "name": "exam_answers",
  "strict": true,
  "schema": {
    "type": "object",
    "description": "答案生成阶段的镜像树 schema。当前仍使用递归结构；如目标 provider 不支持递归 $ref，需要仿照 question_schema.json 展开为固定层数版本。",
    "properties": {
      "answer": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "string" }
          },
          { "type": "null" }
        ],
        "description": "该题的最终答案。选择题填选项标号如 \"C\"；填空题输出字符串数组（对应每个 [[slot]]）；判断题填 \"正确\" 或 \"错误\"；有子题的父题为 null"
      },
      "solution": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "description": "完整的分步解析过程，可包含 LaTeX 公式。有子题的父题为 null"
      },
      "sub_answers": {
        "anyOf": [
          {
            "type": "array",
            "items": { "$ref": "#/$defs/answer_node" }
          },
          { "type": "null" }
        ],
        "description": "子题的答案列表，与 question.sub_questions 按位置一一对应。无子题时为 null"
      }
    },
    "required": ["answer", "solution", "sub_answers"],
    "additionalProperties": false,
    "$defs": {
      "answer_node": {
        "type": "object",
        "description": "单个子题的答案节点（递归结构）",
        "properties": {
          "answer": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              },
              { "type": "null" }
            ],
            "description": "该子题的最终答案，规则同顶层"
          },
          "solution": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "该子题的分步解析过程"
          },
          "sub_answers": {
            "anyOf": [
              {
                "type": "array",
                "items": { "$ref": "#/$defs/answer_node" }
              },
              { "type": "null" }
            ],
            "description": "更深层子题的答案列表，无则为 null"
          }
        },
        "required": ["answer", "solution", "sub_answers"],
        "additionalProperties": false
      }
    }
  }
}
