{
  "name": "exam_questions",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "questions": {
        "type": "array",
        "description": "试卷中所有顶层题目的列表",
        "items": {
          "$ref": "#/$defs/question"
        }
      }
    },
    "required": ["questions"],
    "additionalProperties": false,
    "$defs": {
      "question": {
        "type": "object",
        "description": "一道题目。type 决定哪些字段有意义：choices 类型必须有 options；filling/judging/subjective 的 options 为 null；有子题时 sub_questions 非 null，无子题时为 null。",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["choices", "filling", "judging", "subjective"],
            "description": "题型：choices=选择题, filling=填空题, judging=判断题, subjective=主观题/解答题"
          },
          "stem": {
            "type": "string",
            "description": "题干文本，可包含 LaTeX 公式（$...$ 或 $$...$$）。若是填空题，必须在相应位置使用 [[slot]] 占位符。"
          },
          "stem_images": {
            "type": "array",
            "items": { "type": "string" },
            "description": "题干配图的相对路径列表（如 [\"images/q1_1.png\"]），无图则为空数组 []"
          },
          "fill_slots_count": {
            "type": "integer",
            "minimum": 0,
            "description": "填空题中的空格数量。非填空题填 0。填空位置在 stem 中使用 [[slot]] 标记。"
          },
          "options": {
            "anyOf": [
              {
                "type": "array",
                "items": { "$ref": "#/$defs/option" }
              },
              { "type": "null" }
            ],
            "description": "选择题的选项列表，非选择题为 null"
          },
          "sub_questions": {
            "anyOf": [
              {
                "type": "array",
                "items": { "$ref": "#/$defs/question" }
              },
              { "type": "null" }
            ],
            "description": "子题列表（递归结构），无子题时为 null"
          }
        },
        "required": [
          "type",
          "stem",
          "stem_images",
          "fill_slots_count",
          "options",
          "sub_questions"
        ],
        "additionalProperties": false
      },
      "option": {
        "type": "object",
        "description": "选择题的单个选项",
        "properties": {
          "label": {
            "type": "string",
            "description": "选项标号，如 A、B、C、D"
          },
          "text": {
            "type": "string",
            "description": "选项文本内容，可包含 LaTeX 公式"
          },
          "image": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "选项配图的相对路径，无图则为 null"
          }
        },
        "required": ["label", "text", "image"],
        "additionalProperties": false
      }
    }
  }
}
