{
  "name": "exam_questions",
  "strict": true,
  "schema": {
    "type": "object",
    "description": "Markdown 转题目 JSON 的 provider 兼容 schema。为了兼容 Claude 当前路由，不使用递归 $ref 与 minimum 等更窄 provider 子集不支持的约束；更严格的业务规则下沉到程序校验。",
    "properties": {
      "questions": {
        "type": "array",
        "description": "试卷中所有顶层题目的列表",
        "items": {
          "$ref": "#/$defs/question_level_1"
        }
      }
    },
    "required": ["questions"],
    "additionalProperties": false,
    "$defs": {
      "option": {
        "type": "object",
        "description": "选择题的单个选项",
        "properties": {
          "label": {
            "type": "string",
            "description": "选项标号，如 A、B、C、D"
          },
          "text": {
            "type": "string",
            "description": "选项文本内容，可包含 LaTeX 公式"
          },
          "image": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "选项配图的相对路径，无图则为 null"
          }
        },
        "required": ["label", "text", "image"],
        "additionalProperties": false
      },
      "question_level_1": {
        "type": "object",
        "description": "一道题目。最多允许 5 层题目树；当前为第 1 层。更严格的题型一致性、非负数、题号覆盖率等规则由 validate.py 负责。",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["choices", "filling", "judging", "subjective"],
            "description": "题型：choices=选择题, filling=填空题, judging=判断题, subjective=主观题/解答题"
          },
          "stem": {
            "type": "string",
            "description": "题干文本，可包含 LaTeX 公式（$...$ 或 $$...$$）。若是填空题，必须在相应位置使用 [[slot]] 占位符。"
          },
          "stem_images": {
            "type": "array",
            "items": { "type": "string" },
            "description": "题干配图的相对路径列表（如 [\"images/q1_1.png\"]），无图则为空数组 []"
          },
          "fill_slots_count": {
            "type": "integer",
            "description": "填空题中的空格数量。非填空题通常填 0。是否非负、是否与 [[slot]] 数量一致由程序校验负责。"
          },
          "options": {
            "anyOf": [
              {
                "type": "array",
                "items": { "$ref": "#/$defs/option" }
              },
              { "type": "null" }
            ],
            "description": "选择题的选项列表，非选择题为 null"
          },
          "sub_questions": {
            "anyOf": [
              {
                "type": "array",
                "items": { "$ref": "#/$defs/question_level_2" }
              },
              { "type": "null" }
            ],
            "description": "子题列表，无子题时为 null"
          }
        },
        "required": [
          "type",
          "stem",
          "stem_images",
          "fill_slots_count",
          "options",
          "sub_questions"
        ],
        "additionalProperties": false
      },
      "question_level_2": {
        "type": "object",
        "description": "一道题目。最多允许 5 层题目树；当前为第 2 层。更严格的题型一致性、非负数、题号覆盖率等规则由 validate.py 负责。",
        "properties": {
