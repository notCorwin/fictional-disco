              { "type": "null" }
            ],
            "description": "选择题的选项列表，非选择题为 null"
          },
          "sub_questions": {
            "anyOf": [
              {
                "type": "array",
                "items": { "$ref": "#/$defs/question_level_3" }
              },
              { "type": "null" }
            ],
            "description": "子题列表，无子题时为 null"
          }
        },
        "required": [
          "type",
          "stem",
          "stem_images",
          "fill_slots_count",
          "options",
          "sub_questions"
        ],
        "additionalProperties": false
      },
